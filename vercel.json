{
  // 构建命令：使用 pnpm 执行 build 脚本
  "buildCommand": "pnpm build",

  // 输出目录：构建产物存放位置
  "outputDirectory": "dist",

  // 安装命令：使用 pnpm 安装依赖
  "installCommand": "pnpm install",

  // 框架类型：指定为 Astro
  "framework": "astro",

  // 自定义 HTTP 响应头配置
  "headers": [
    {
      // 应用于所有路径
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"  // 防止浏览器猜测 MIME 类型
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"     // 禁止在 iframe 中加载
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"  // 启用 XSS 防护
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"  // 控制 Referrer 信息
        }
      ]
    },
    {
      // 应用于 Astro 资源目录
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"  // 永久缓存静态资源
        }
      ]
    }
  ],

  // 移除 URL 中的 .html 后缀
  "cleanUrls": true
}